# ─── BASE DE DATOS (Neon PostgreSQL) ───────────────────────────────────────
# Copia tu connection string desde el dashboard de Neon
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/inventario?sslmode=require"

# ─── AUTENTICACIÓN (NextAuth) ───────────────────────────────────────────────
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secreto-aleatorio-aqui"

# En desarrollo
NEXTAUTH_URL="http://localhost:3000"

# En producción (Vercel lo pone automáticamente, no necesitas agregarlo)
# NEXTAUTH_URL="https://tu-app.vercel.app"
